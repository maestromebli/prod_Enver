# Фрагмент .env для виробничого модуля ENVER OS
# Додайте до основного .env на сервері (/opt/enver/.env)

NODE_ENV=production
PORT=3000

# Postgres (обов'язково)
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL_MIGRATIONS=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# AI-зіставлення логів станка (опційно; можна задати в UI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Приклад шляхів до логів на сервері цеху (задаються також у Налаштування → Станки)
# MACHINE_LOG_CUTTING=/var/log/stanki/viyar-cut.log
# MACHINE_LOG_EDGING=/var/log/stanki/edging.log
