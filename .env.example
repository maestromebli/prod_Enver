# Скопіюйте в .env для локального запуску, або налаштуйте на сервері у /opt/enver/.env
NODE_ENV=production
PORT=3000

# Supabase Postgres
# Runtime (рантайм-контейнер): pooler, transaction mode, port 6543
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Тільки для CI міграцій: direct, port 5432
DATABASE_URL_MIGRATIONS=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Caddy / reverse proxy
DOMAIN=enver.example.com

# Опційно — webhook автоматизації (n8n / Make). Після зміни: npm run automation:apply
# AUTOMATION_PRODUCTION_WEBHOOK_URL=https://hooks.example.com/enver-production
# AUTOMATION_OVERDUE_WEBHOOK_URL=https://hooks.example.com/enver-overdue
# AUTOMATION_PROCUREMENT_WEBHOOK_URL=https://hooks.example.com/enver-procurement
# AUTOMATION_SHADOW_MODE=true

# Секрет сесій (обов'язковий у production — не залишайте dev-значення)
SESSION_SECRET=замініть-на-випадковий-рядок

# OpenAI — опційно, для ШІ-аналізу конструктивів
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Каталог файлів конструктивів (у Docker: /data/uploads, volume enver-uploads)
UPLOADS_DIR=./data/uploads

# Початковий пароль admin при seed (одноразово). У production — не 'admin'.
ADMIN_DEFAULT_PASSWORD=admin
