# Скопіюйте в .env для продакшену
NODE_ENV=production
PORT=3000

# Секрет для майбутніх розширень сесій
SESSION_SECRET=змініть-на-випадковий-рядок

# OpenAI — опційно, для AI-зіставлення логів станка з позиціями
# Можна також задати в Налаштування → Станки → OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
