@model AssetManagement.Core.Models.PagedResult<AssetManagement.Core.Models.AssetStatusForTenantDto>
@{
    var tenant = (AssetManagement.Core.Models.TenantSummary)ViewBag.Tenant!;
    ViewData["Title"] = $"Активи — {tenant.Name}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Усі tenant</a></li>
        <li class="breadcrumb-item active">@tenant.Name</li>
    </ol>
</nav>

<h1 class="mb-2">@tenant.Name</h1>
@if (!string.IsNullOrWhiteSpace(tenant.Description))
{
    <p class="text-muted">@tenant.Description</p>
}

<p class="text-muted">
    Активів: @Model.TotalCount · сторінка @Model.PageIndex з @(Model.TotalPages == 0 ? 1 : Model.TotalPages)
</p>

<div class="table-responsive card shadow-sm">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Тип</th>
                <th>Назва</th>
                <th>Статус</th>
                <th>Оновлено</th>
                <th>Ким</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var asset in Model.Items)
            {
                <tr>
                    <td>@asset.AssetType</td>
                    <td>@asset.AssetName</td>
                    <td>
                        <span class="badge bg-@StatusBadgeClass(asset.Status)">@asset.Status</span>
                    </td>
                    <td>@asset.LastUpdated.ToString("yyyy-MM-dd HH:mm") UTC</td>
                    <td>@asset.UpdatedBy</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@asset.AssetId" class="btn btn-sm btn-outline-secondary">Редагувати</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_Pagination", new AssetManagement.Web.Models.PageNavigationModel
{
    PageIndex = Model.PageIndex,
    PageSize = Model.PageSize,
    TotalPages = Model.TotalPages,
    HasPreviousPage = Model.HasPreviousPage,
    HasNextPage = Model.HasNextPage,
    Action = "Details",
    RouteValues = new Dictionary<string, string?>
    {
        ["tenantId"] = tenant.Id.ToString(),
        ["pageSize"] = Model.PageSize.ToString()
    }
})

@functions {
    string StatusBadgeClass(AssetManagement.Core.Enums.AssetStatus status) => status switch
    {
        AssetManagement.Core.Enums.AssetStatus.Active => "success",
        AssetManagement.Core.Enums.AssetStatus.Inactive => "secondary",
        AssetManagement.Core.Enums.AssetStatus.Maintenance => "warning",
        AssetManagement.Core.Enums.AssetStatus.Decommissioned => "danger",
        _ => "secondary"
    };
}
