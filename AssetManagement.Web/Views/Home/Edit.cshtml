@model AssetManagement.Web.Controllers.EditAssetStatusViewModel
@{
    ViewData["Title"] = $"Редагування — {Model.AssetName}";
}

<h1 class="mb-4">Редагування статусу</h1>

<dl class="row mb-4">
    <dt class="col-sm-3">Тип</dt>
    <dd class="col-sm-9">@Model.AssetType</dd>
    <dt class="col-sm-3">Назва</dt>
    <dd class="col-sm-9">@Model.AssetName</dd>
    <dt class="col-sm-3">Поточний статус</dt>
    <dd class="col-sm-9"><span class="badge bg-secondary">@Model.CurrentStatus</span></dd>
</dl>

<form asp-action="Edit" method="post" class="card p-4 shadow-sm" style="max-width: 32rem;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AssetId" />
    <input type="hidden" asp-for="AssetName" />
    <input type="hidden" asp-for="AssetType" />
    <input type="hidden" asp-for="CurrentStatus" />

    <div class="mb-3">
        <label asp-for="NewStatus" class="form-label">Новий статус</label>
        <select asp-for="NewStatus" asp-items="Html.GetEnumSelectList<AssetManagement.Core.Enums.AssetStatus>()" class="form-select"></select>
        <span asp-validation-for="NewStatus" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UpdatedBy" class="form-label">Оновив (користувач)</label>
        <input asp-for="UpdatedBy" class="form-control" />
        <span asp-validation-for="UpdatedBy" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Зберегти</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
