@model AssetManagement.Web.Models.PageNavigationModel

@if (Model.TotalPages > 1)
{
    <nav aria-label="Пагінація" class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@PageUrl(Model.PageIndex - 1)">Попередня</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="@PageUrl(i)">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@PageUrl(Model.PageIndex + 1)">Наступна</a>
            </li>
        </ul>
    </nav>
}

@functions {
    string PageUrl(int pageIndex)
    {
        var query = new Dictionary<string, string?>(Model.RouteValues)
        {
            ["pageIndex"] = pageIndex.ToString(),
            ["pageSize"] = Model.PageSize.ToString()
        };

        var path = Url.Action(Model.Action)!;
        return path + "?" + string.Join("&", query.Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value ?? "")}"));
    }
}
