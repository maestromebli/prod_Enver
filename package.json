{
  "name": "enver-production",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "dev": "npm run migrate --prefix server && npm run dev --prefix server",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "build": "npm run build --prefix client",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "build:android-client": "cd desktop/android && ./gradlew assembleRelease && node scripts/copy-release.mjs",
    "pack:production-module": "node scripts/pack-production-module.mjs",
    "demo:workflow": "node server/scripts/demo-workflow.mjs",
    "start": "npm run build --prefix client && npm run start --prefix server",
    "test": "npm run test --prefix server && npm run test:client && npm run test:b3d-converter",
    "test:b3d-converter": "python3 -m pip install -q ./tools/b3d-converter[dev] && cd tools/b3d-converter && python3 -m pytest -q",
    "test:coverage": "npm run test:coverage --prefix server",
    "test:coverage:check": "node scripts/check-coverage.mjs",
    "test:coverage:shared": "npm run test:coverage:shared --prefix server",
    "quality:check": "node scripts/quality-score.mjs",
    "test:client": "node --test client/test/*.test.js",
    "test:e2e": "playwright test -c e2e/playwright.config.js",
    "test:e2e:visual": "playwright test -c e2e/playwright.config.js e2e/specs/visual-audit.spec.js",
    "typecheck": "tsc -p shared/tsconfig.json && tsc -p server/tsconfig.json",
    "migrate": "npm run migrate --prefix server",
    "automation:apply": "node server/scripts/apply-automation-production.mjs",
    "seed": "npm run migrate --prefix server",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npm run lint -- --max-warnings 0 && npm run typecheck && npm test && npm run quality:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@types/express": "^5.0.0",
    "@types/node": "^26.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
