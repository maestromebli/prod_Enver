{
  "name": "enver-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../.env NODE_ENV=development node -r dotenv/config src/index.js",
    "start": "DOTENV_CONFIG_PATH=../.env NODE_ENV=production node -r dotenv/config src/index.js",
    "migrate": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config scripts/migrate.mjs",
    "resync:bazis": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config scripts/resync-bazis-codes.mjs",
    "test": "node --test test/*.test.js test/integration/*.test.mjs",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=src/**/*.js --test-coverage-include=../shared/production/**/*.js test/*.test.js test/integration/*.test.mjs",
    "test:integration": "node --test test/integration/*.test.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.2.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "vite": "^6.4.2"
  }
}
